# ---------- Required ----------
# Massive API key. Get a free key at https://massive.com
MASSIVE_API_KEY=your_massive_key_here

# ---------- Storage ----------
# Bronze layer URI — local FS by default. For prod, set to an S3 URI:
#   BRONZE_URI=s3://my-bucket/bronze/
BRONZE_URI=./data/bronze

# DuckDB file path (silver + gold + meta tables)
DUCKDB_PATH=./data/warehouse.duckdb

# ---------- Optional: S3 / MinIO ----------
# Only needed when BRONZE_URI starts with s3://
# S3_ENDPOINT=http://localhost:9000      # MinIO or localstack
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ---------- Optional: Observability ----------
# Healthchecks.io ping URL for cron monitoring (empty = no ping)
# HEALTHCHECK_URL=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Git SHA recorded into meta.pipeline_runs (usually set by CI or the Makefile)
# GIT_SHA=
